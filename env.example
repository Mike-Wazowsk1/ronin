# Environment variables for ronin-nft-bridge
# Add these to your ~/.bashrc or ~/.zshrc

# Rust
export PATH="$HOME/.cargo/bin:$PATH"

# Solana CLI
export PATH="$HOME/solana-release/bin:$PATH"

# Anchor CLI compatibility wrapper
export PATH="$HOME/.local/bin:$PATH"

# Node.js (if installed via nvm)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Project specific
export RONIN_BRIDGE_ROOT="$(pwd)"
export ANCHOR_VERSION="0.29.0"
export SOLANA_VERSION="1.18.26"
export RUST_VERSION="nightly"

# Optional: Set RPC endpoints
# export SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# export SOLANA_WS_URL="wss://api.mainnet-beta.solana.com"

# Optional: Set keypair path
# export SOLANA_KEYPAIR_PATH="$HOME/.config/solana/id.json"
